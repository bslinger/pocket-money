{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "build:ssr": "tsc && vite build && vite build --ssr",
        "dev": "vite",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:coverage": "COLLECT_COVERAGE=true playwright test && node --import tsx/esm tests/e2e/coverage-report.mts",
        "coverage:e2e": "node --import tsx/esm tests/e2e/coverage-report.mts",
        "coverage:pest": "XDEBUG_MODE=coverage ./vendor/bin/sail artisan test --coverage-html storage/coverage/pest/html --coverage-clover storage/coverage/pest/clover.xml"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^3.0.0-beta.5",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^20.19.37",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.4.12",
        "concurrently": "^9.0.1",
        "istanbul-lib-coverage": "^3.2.2",
        "istanbul-lib-report": "^3.0.1",
        "istanbul-reports": "^3.2.0",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^3.2.1",
        "tsx": "^4.21.0",
        "typescript": "^5.0.2",
        "v8-to-istanbul": "^9.3.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@capacitor/android": "^8.2.0",
        "@capacitor/app": "^8.0.1",
        "@capacitor/camera": "^8.0.2",
        "@capacitor/cli": "^8.2.0",
        "@capacitor/core": "^8.2.0",
        "@capacitor/filesystem": "^8.1.2",
        "@capacitor/splash-screen": "^8.0.1",
        "@inertiajs/vite": "^3.0.0-beta.5",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@types/pluralize": "^0.0.33",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "emoji-picker-react": "^4.18.0",
        "lucide-react": "^0.577.0",
        "pluralize": "^8.0.0",
        "qs-esm": "^7.0.3",
        "react-easy-crop": "^5.5.6",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7"
    }
}
