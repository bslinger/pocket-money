---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Quiddo — Pocket money, sorted. The app for Aussie families who want their kids to earn, save, and learn." />
    <title>Quiddo — Pocket money, sorted.</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-bark-50 text-bark-700 font-body">
    <!-- Sticky Nav -->
    <header class="bg-white border-b border-bark-200 sticky top-0 z-50 shadow-sm">
      <div class="mx-auto max-w-6xl px-6 h-[60px] flex items-center justify-between">
        <a href="/" class="font-display text-[22px] font-bold text-eucalyptus-400 tracking-tight">
          Quiddo
        </a>
        <nav class="hidden md:flex items-center gap-7 text-sm font-medium text-bark-600">
          <a href="#how" class="hover:text-eucalyptus-400 transition-colors">How it works</a>
          <a href="#pricing" class="hover:text-eucalyptus-400 transition-colors">Pricing</a>
          <a href="#faq" class="hover:text-eucalyptus-400 transition-colors">FAQ</a>
        </nav>
        <a
          href="#waitlist-form"
          class="bg-eucalyptus-400 text-white text-sm font-semibold px-5 py-2 rounded-full hover:bg-eucalyptus-500 transition-colors"
        >
          Join the waitlist
        </a>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-eucalyptus-600 text-white/55 pt-14 pb-8">
      <div class="mx-auto max-w-6xl px-6">
        <!-- 4-col top -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
          <!-- Col 1 — brand -->
          <div>
            <p class="font-display text-2xl font-bold text-wattle-300 mb-3">Quiddo</p>
            <p class="text-sm leading-relaxed mb-5">
              Pocket money, sorted. The app for Aussie families who want their kids to earn, save, and learn — without the spreadsheets.
            </p>
            <div class="flex gap-2.5">
              <button class="bg-white/10 border border-white/20 rounded-lg px-3.5 py-2 text-xs font-semibold text-white/80 flex items-center gap-1.5 hover:bg-white/20 transition-colors">
                🍎 App Store
              </button>
              <button class="bg-white/10 border border-white/20 rounded-lg px-3.5 py-2 text-xs font-semibold text-white/80 flex items-center gap-1.5 hover:bg-white/20 transition-colors">
                ▶ Google Play
              </button>
            </div>
          </div>

          <!-- Col 2 -->
          <div>
            <h4 class="text-[11px] font-bold uppercase tracking-[0.6px] text-white/40 mb-4">Get to know us</h4>
            <ul class="flex flex-col gap-2.5">
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">About</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Blog</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Careers</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Col 3 -->
          <div>
            <h4 class="text-[11px] font-bold uppercase tracking-[0.6px] text-white/40 mb-4">Let us help you</h4>
            <ul class="flex flex-col gap-2.5">
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Help centre</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Getting started</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">FAQ</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Contact support</a></li>
            </ul>
          </div>

          <!-- Col 4 -->
          <div>
            <h4 class="text-[11px] font-bold uppercase tracking-[0.6px] text-white/40 mb-4">The app</h4>
            <ul class="flex flex-col gap-2.5">
              <li><a href="#how" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">How it works</a></li>
              <li><a href="#pricing" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Pricing</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">iOS App</a></li>
              <li><a href="#" class="text-sm text-white/55 hover:text-wattle-300 transition-colors">Android App</a></li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/40">
          <span>&copy; 2026 Quiddo Pty Ltd &middot; quiddo.com.au</span>
          <div class="flex gap-5">
            <a href="#" class="hover:text-white/70 transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-white/70 transition-colors">Terms of Service</a>
            <a href="#" class="hover:text-white/70 transition-colors">Accessibility</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
